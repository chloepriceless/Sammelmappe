# Sammelmappe Configuration

# Server
HOST=0.0.0.0
PORT=8080

# Storage
DATA_DIR=./data

# Auth: secret for signing session cookies (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-to-random-string-on-install
SESSION_HOURS=720

# OCR
TESSERACT_CMD=tesseract
TESSERACT_LANG=deu+eng

# Claude Vision Fallback (optional but recommended)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Behavior
# If Tesseract confidence is below this, fall back to Claude Vision (0..1)
OCR_CONFIDENCE_THRESHOLD=0.6
# Hard cap on upload size (MiB)
MAX_UPLOAD_MIB=25
